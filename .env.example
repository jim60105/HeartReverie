# HeartReverie 浮心夜夢 — Environment Variables
# Copy this file to .env and fill in the values.
# Lines starting with # are comments.

# ── LLM API ──────────────────────────────────────────────────────

# API key for the LLM provider (required for chat functionality)
LLM_API_KEY=your-api-key-here

# LLM model identifier (default: deepseek/deepseek-v4-pro)
# LLM_MODEL=deepseek/deepseek-v4-pro

# LLM chat completions endpoint URL (default: OpenRouter)
# Change this to use any OpenAI-compatible provider.
# LLM_API_URL=https://openrouter.ai/api/v1/chat/completions

# ── LLM Sampling Parameters ─────────────────────────────────────
# All parameters are optional. Defaults match the original hardcoded values.

# LLM_TEMPERATURE=0.1
# LLM_FREQUENCY_PENALTY=0.13
# LLM_PRESENCE_PENALTY=0.52
# LLM_TOP_K=10
# LLM_TOP_P=0
# LLM_REPETITION_PENALTY=1.2
# LLM_MIN_P=0
# LLM_TOP_A=1

# Maximum total completion tokens (reasoning + content). Always sent as
# `max_completion_tokens` to the LLM provider. Must be a positive integer.
# LLM_MAX_COMPLETION_TOKENS=4096

## LLM Reasoning
# LLM_REASONING_ENABLED=true
# LLM_REASONING_EFFORT=xhigh
# Set to true to suppress the `reasoning` block entirely (for strict OpenAI-compatible providers that reject unknown fields)
# LLM_REASONING_OMIT=false

# ── Server ───────────────────────────────────────────────────────

# HTTPS listening port (default: 8443)
# PORT=8443

# API authentication passphrase. When set, all /api/ requests must
# include a matching X-Passphrase header. Leave unset for open access.
PASSPHRASE=your-passphrase-here

# ── Display ──────────────────────────────────────────────────────

# Background image URL path for the web reader (default: /assets/heart.webp)
# BACKGROUND_IMAGE=/assets/heart.webp

# ── Paths ────────────────────────────────────────────────────────

# Story data directory (default: ./playground)
# PLAYGROUND_DIR=./playground

# Frontend static files directory (default: ./reader-dist)
# READER_DIR=./reader-dist

# External plugin directory (absolute path, optional)
# PLUGIN_DIR=

# Custom prompt template file path (default: playground/_prompts/system.md)
# PROMPT_FILE=playground/_prompts/system.md

# ── TLS ──────────────────────────────────────────────────────────

# Set to true to disable TLS (for reverse-proxy / K8s deployments)
# HTTP_ONLY=true

# Custom TLS certificate and key file paths
# (auto-generated self-signed cert is used when these are not set and HTTP_ONLY is not true)
# CERT_FILE=
# KEY_FILE=

# ── Logging ──────────────────────────────────────────────────────

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# Path to audit log JSON Lines file (empty string disables file logging)
# LOG_FILE=playground/_logs/audit.jsonl

# Path to LLM interaction log file (full request/response; empty string disables)
# LLM_LOG_FILE=playground/_logs/llm.jsonl
