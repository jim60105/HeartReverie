# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/
# OS junk
Thumbs.db
# Repo-level dirs that have no business in a chart tarball
.github/
.agents/
node_modules/
coverage/
playground/
tmp/
docs/
openspec/
plugins/
reader-src/
reader-dist/
writer/
tests/
scripts/
.certs/
# Markdown outside the chart
/README.md
/CHANGELOG.md
/AGENTS.md
