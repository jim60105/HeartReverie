{
  "version": "0.9.0",
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false,
    "semiColons": true,
    "proseWrap": "preserve",
    "include": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.json",
      "**/*.jsonc",
      "**/*.yaml",
      "**/*.yml",
      "**/*.css"
    ],
    "exclude": [
      "**/*.md",
      "**/node_modules/",
      "**/vendor/",
      "reader-dist/",
      "coverage/",
      "coverage.lcov",
      "playground/",
      "themes/",
      "helm/heart-reverie/templates/",
      "openspec/changes/archive/",
      "docs/index.html"
    ]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["require-await", "no-import-prefix", "no-unversioned-import"]
    },
    "include": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx"
    ],
    "exclude": [
      "**/node_modules/",
      "**/vendor/",
      "reader-dist/",
      "coverage/",
      "playground/",
      "themes/",
      "openspec/changes/archive/"
    ]
  },
  "tasks": {
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "start": "deno run --allow-net --allow-read --allow-write --allow-env --allow-run writer/server.ts",
    "dev:reader": "cd reader-src && deno run -A npm:vite@^8.0.0",
    "build:reader": "cd reader-src && deno run -A npm:vue-tsc@^3.0.0 --noEmit && deno run -A npm:vite@^8.0.0 build --outDir ../reader-dist",
    "test:backend": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run tests/writer/ tests/plugins/ tests/themes/ scripts/__tests__/",
    "test:backend:coverage": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run --coverage=coverage/backend tests/writer/ tests/plugins/ tests/themes/ scripts/__tests__/ && deno coverage coverage/backend --lcov --output=coverage/backend.lcov --exclude='tests/' --exclude='HeartReverie_Plugins/'",
    "test:frontend": "cd reader-src && deno run -A npm:vitest@^4.0.0 run",
    "test:frontend:coverage": "cd reader-src && deno run -A npm:vitest@^4.0.0 run --coverage",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net --allow-run tests/writer/ tests/plugins/ tests/themes/ scripts/__tests__/ && cd reader-src && deno run -A npm:vitest@^4.0.0 run",
    "coverage:clean": "rm -rf coverage/backend coverage/frontend coverage/backend.lcov coverage.lcov",
    "coverage:merge": "deno run --allow-read --allow-write scripts/coverage.ts merge coverage/backend.lcov coverage/frontend/lcov.info coverage.lcov",
    "coverage:summary": "deno run --allow-read scripts/coverage.ts summary coverage.lcov",
    "coverage:threshold": "deno run --allow-read scripts/coverage.ts gate coverage.lcov 85",
    "test:coverage": "deno task coverage:clean && deno task test:backend:coverage && deno task test:frontend:coverage && deno task coverage:merge && deno task coverage:summary && deno task coverage:threshold",
    "introspect:hooks": "deno run --allow-net --allow-read --allow-write --allow-env --allow-run scripts/introspect-hooks.ts",
    "check:vento-helpers": "deno run --allow-read --allow-env scripts/check-vento-helpers.ts"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.12.14",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/crypto": "jsr:@std/crypto@^1.0.5",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@std/toml": "jsr:@std/toml@^1.0.6",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "@std/yaml": "jsr:@std/yaml@^1.0.12",
    "ventojs": "npm:ventojs@^2.3.1",
    "vue": "npm:vue@^3.5.32",
    "vue-router": "npm:vue-router@^5.0.4",
    "marked": "npm:marked@^18.0.0",
    "dompurify": "npm:dompurify@^3.4.0",
    "@codemirror/state": "npm:@codemirror/state@^6.5.2",
    "@codemirror/view": "npm:@codemirror/view@^6.38.0",
    "@codemirror/language": "npm:@codemirror/language@^6.11.0",
    "@codemirror/lint": "npm:@codemirror/lint@^6.8.5",
    "@codemirror/autocomplete": "npm:@codemirror/autocomplete@^6.18.6",
    "@codemirror/commands": "npm:@codemirror/commands@^6.8.1",
    "@lezer/highlight": "npm:@lezer/highlight@^1.2.3",
    "@vueuse/core": "npm:@vueuse/core@^12.0.0",
    "diff": "npm:diff@^7.0.0",
    "@vitejs/plugin-vue": "npm:@vitejs/plugin-vue@^6.0.0",
    "@vitest/coverage-v8": "npm:@vitest/coverage-v8@^4.0.0",
    "@vue/test-utils": "npm:@vue/test-utils@^2.4.6",
    "happy-dom": "npm:happy-dom@^20.9.0",
    "postcss": "npm:postcss@^8.5.10",
    "tailwindcss": "npm:tailwindcss@^4.0.0",
    "@tailwindcss/postcss": "npm:@tailwindcss/postcss@^4.0.0",
    "typescript": "npm:typescript@^6.0.0",
    "vite": "npm:vite@^8.0.0",
    "vitest": "npm:vitest@^4.0.0",
    "vue-tsc": "npm:vue-tsc@^3.0.0"
  }
}
