{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-write --allow-env --allow-run writer/server.ts",
    "test:backend": "deno test --allow-read --allow-write --allow-env --allow-net tests/writer/",
    "test:frontend": "deno test --allow-read tests/reader/js/",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net tests/writer/ tests/reader/js/"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4",
    "@std/path": "jsr:@std/path@^1",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/crypto": "jsr:@std/crypto@^1",
    "@std/dotenv": "jsr:@std/dotenv@^0.225",
    "@std/testing": "jsr:@std/testing@^1",
    "@std/yaml": "jsr:@std/yaml@^1",
    "ventojs": "npm:ventojs@^2.3.1"
  }
}
