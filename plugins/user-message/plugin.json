{
  "name": "user-message",
  "version": "1.0.0",
  "description": "User message lifecycle: wrap input in tags, strip from context and display",
  "type": "full-stack",
  "backendModule": "./handler.ts",
  "hooks": [
    {
      "stage": "pre-write",
      "writes": [
        "preContent"
      ]
    }
  ],
  "displayStripTags": [
    "user_message"
  ],
  "tags": [
    "user_message"
  ],
  "promptStripTags": [
    "user_message"
  ],
  "settingsSchema": {
    "type": "object",
    "x-schema-version": 1,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "title": "啟用使用者訊息標記",
        "description": "關閉後本外掛將停用，等同未安裝外掛。"
      }
    }
  }
}
