{
  "name": "user-message",
  "displayName": "使用者訊息",
  "version": "1.0.0",
  "description": "使用者訊息生命週期：將輸入包裝於標籤中、從上下文中移除並顯示",
  "type": "full-stack",
  "backendModule": "./handler.ts",
  "hooks": [
    {
      "stage": "pre-write",
      "writes": [
        "preContent"
      ]
    }
  ],
  "displayStripTags": [
    "user_message"
  ],
  "tags": [
    "user_message"
  ],
  "promptStripTags": [
    "user_message"
  ],
  "settingsSchema": {
    "type": "object",
    "x-schema-version": 1,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "title": "啟用使用者訊息標記",
        "description": "關閉後此功能將停用。"
      }
    }
  }
}
