{
  "name": "dialogue-colorize",
  "version": "1.0.0",
  "description": "Colourise dialogue runs (matched quote pairs) via the CSS Custom Highlight API without modifying the DOM",
  "type": "frontend-only",
  "frontendModule": "./frontend.js",
  "hooks": [
    {
      "stage": "chapter:dom:ready"
    },
    {
      "stage": "chapter:dom:dispose"
    }
  ],
  "frontendStyles": [
    "./styles.css"
  ],
  "settingsSchema": {
    "type": "object",
    "x-schema-version": 1,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "title": "啟用對話上色",
        "description": "關閉後此功能將停用。"
      },
      "dialogueColor": {
        "type": "string",
        "default": "",
        "title": "對話顏色",
        "description": "套用至引號內對話文字的顏色，可填入色碼（例如 #aa5500）或顏色名稱（例如 royalblue）。留空則沿用目前佈景主題的預設顏色。"
      },
      "enabledQuoteStyles": {
        "type": "array",
        "default": [
          "straight",
          "curly",
          "guillemet",
          "corner",
          "corner-half",
          "book"
        ],
        "title": "要上色的引號樣式",
        "description": "勾選要套用顏色的引號類型。未勾選的引號內文字將維持原本顏色。",
        "items": {
          "type": "string",
          "enum": [
            "straight",
            "curly",
            "guillemet",
            "corner",
            "corner-half",
            "book"
          ]
        }
      }
    }
  }
}
