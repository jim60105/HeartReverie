{
  "name": "context-compaction",
  "displayName": "脈絡壓縮",
  "version": "1.0.0",
  "description": "透過內嵌章節摘要進行分層式脈絡壓縮",
  "type": "full-stack",
  "promptFragments": [
    {
      "file": "./chapter-summary-instruction.md",
      "variable": "context_compaction",
      "priority": 800
    }
  ],
  "promptStripTags": [
    "chapter_summary"
  ],
  "displayStripTags": [
    "chapter_summary"
  ],
  "backendModule": "./handler.ts",
  "hooks": [
    {
      "stage": "prompt-assembly",
      "writes": [
        "previousContext"
      ]
    }
  ],
  "settingsSchema": {
    "type": "object",
    "x-schema-version": 1,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "title": "啟用脈絡壓縮",
        "description": "關閉後本外掛將停用，等同未安裝外掛。"
      },
      "recentChapters": {
        "type": "integer",
        "minimum": 1,
        "default": 3,
        "title": "保留原文的章節數",
        "description": "保留最近幾個章節的完整原文，更早的章節會自動壓縮成摘要以節省字數。設大一點可保留更多原文細節，但模型讀取量會增加。最少一章。"
      }
    }
  }
}
