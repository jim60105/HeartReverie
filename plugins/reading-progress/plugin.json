{
  "name": "reading-progress",
  "version": "1.0.0",
  "description": "Single-user, multi-device reading progress sync (chapter index + scroll ratio + text fragment anchor)",
  "type": "full-stack",
  "frontendModule": "./frontend.js",
  "backendModule": "./backend.ts",
  "hooks": [],
  "settingsSchema": {
    "x-schema-version": 1,
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "title": "啟用閱讀進度同步"
      },
      "syncIntervalSeconds": {
        "type": "number",
        "minimum": 1,
        "maximum": 60,
        "default": 5,
        "title": "捲動同步節流秒數"
      },
      "storageBackend": {
        "type": "string",
        "enum": ["file", "local"],
        "default": "file",
        "title": "儲存後端"
      },
      "pollOnFocus": {
        "type": "boolean",
        "default": true,
        "title": "切回頁面時重新抓取"
      },
      "pollIntervalMs": {
        "type": "number",
        "minimum": 0,
        "maximum": 600000,
        "default": 0,
        "title": "輪詢間隔（毫秒）"
      },
      "confirmRemoteJump": {
        "type": "boolean",
        "default": true,
        "title": "跨裝置跳轉前確認"
      },
      "retainDays": {
        "type": "number",
        "minimum": 1,
        "maximum": 3650,
        "default": 90,
        "title": "進度保留天數"
      },
      "trackSelectionAnchor": {
        "type": "boolean",
        "default": true,
        "title": "記錄文字錨點"
      }
    }
  }
}
